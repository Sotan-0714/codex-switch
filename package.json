{
  "name": "apivot",
  "version": "1.0.1",
  "description": "Local-first desktop tool for safely switching Codex and Claude Code profiles without breaking official environments.",
  "main": "src/main/main.js",
  "author": "Hardcopia <1300858541@qq.com>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "build:renderer": "vite build",
    "test": "node --test test/*.test.js",
    "typecheck": "tsc --noEmit",
    "qa:vite": "node scripts/qa-vite-smoke.cjs",
    "qa:electron": "npm run build:renderer && node scripts/qa-electron-smoke.cjs",
    "qa:all": "npm run test && npm run typecheck && npm run build:renderer && npm run qa:vite && npm run qa:electron",
    "legal:notices": "node scripts/generate-third-party-notices.cjs",
    "pack": "electron-builder --dir",
    "dist": "node scripts/build-portable-versioned.cjs",
    "dist:win": "npm run legal:notices && npm run build:renderer && electron-builder --win portable nsis --x64 --publish never",
    "dist:mac": "npm run legal:notices && npm run build:renderer && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "dist:preview": "node scripts/build-portable-versioned.cjs --dry-run",
    "dist:current": "npm run build:renderer && electron-builder --win portable"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12",
    "playwright": "^1.60.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "overrides": {
    "form-data": "^4.0.6"
  },
  "build": {
    "appId": "local.apivot",
    "productName": "Apivot",
    "copyright": "Copyright (C) 2026 Hardcopia",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer-dist/**/*",
      "legal/**/*",
      "LICENSE",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "legal",
        "to": "legal"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "Apivot-Portable-${version}-${arch}.${ext}"
    }
  }
}
